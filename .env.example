# Supabase — find these in app.supabase.com → Project Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Used by Vite (client-side bundle) — must match SUPABASE_* above
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=yourprojectid

# Supabase management API token — only used for local CLI operations (migrations)
SUPABASE_ACCESS_TOKEN=sbp_...

# Your deployed admin app URL (no trailing slash)
APP_URL=https://wink-admin.workers.dev
